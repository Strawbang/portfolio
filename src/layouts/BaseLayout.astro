---
// Learn about using Astro layouts:
// https://docs.astro.build/en/core-concepts/layouts/

// Component Imports
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
	canonicalURL?: string | undefined;
	image?: string | undefined;
	type?: 'website' | 'article';
	publishedTime?: string | undefined;
	updatedTime?: string | undefined;
	tags?: string[];
}

const { title, description, canonicalURL, image, type, publishedTime, updatedTime, tags } = Astro.props;

import { getLangFromUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
---

<html lang={lang}>
	<head>
		<MainHead 
			title={title} 
			description={description} 
			canonicalURL={canonicalURL}
			image={image}
			type={type}
			publishedTime={publishedTime}
			updatedTime={updatedTime}
			tags={tags}
		/>
		<ClientRouter />
		<slot name="head" />
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to main content</a>
		<div class="stack backgrounds">
			<Nav />
			<div id="main-content" tabindex="-1">
				<slot />
			</div>
			<Footer />
		</div>
		<BackToTop />

		<style>
			.backgrounds {
				min-height: 100%;
				isolation: isolate;
				background:
					radial-gradient(ellipse 100% 70% at 65% -5%, var(--accent-overlay) 0%, transparent 65%),
					linear-gradient(180deg, var(--gray-900) 0%, var(--gray-999) 40%),
					var(--gray-999);
			}
			@media (forced-colors: active) {
				.backgrounds {
					background: none;
				}
			}
			.skip-link {
				position: absolute;
				top: -100%;
				left: 0;
				z-index: 99999;
				padding: 0.75rem 1.5rem;
				background: var(--accent-regular);
				color: var(--accent-text-over);
				text-decoration: none;
				font-weight: 600;
				border-radius: 0 0 0.5rem 0;
				transition: top 0.2s;
			}
			.skip-link:focus {
				top: 0;
			}
		</style>
	</body>
</html>
