---
import FrenchBaseLayout from "../../../layouts/FrenchBaseLayout.astro";
import Icon from "../../../components/Icon.astro";
---

<FrenchBaseLayout
  title="Message envoyé — Djamel Bougouffa"
  description="Votre message a bien été envoyé."
>
  <div class="stack gap-20">
    <main class="wrapper success">
      <div class="success-content">
        <span class="icon-wrap"><Icon icon="paper-plane-tilt" size="3em" /></span>
        <h1>Message envoyé !</h1>
        <p>Merci pour votre message. Je vous répondrai dans les plus brefs délais, généralement sous un ou deux jours.</p>
        <a href="/fr/" class="back-btn">← Retour à l'accueil</a>
      </div>
    </main>
  </div>
</FrenchBaseLayout>

<style>
  .success {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
  }

  .success-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    max-width: 36rem;
    padding: 4rem 2rem;
  }

  .icon-wrap {
    color: var(--accent-regular);
  }

  h1 {
    font-size: var(--text-3xl);
    color: var(--gray-0);
  }

  p {
    color: var(--gray-300);
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .back-btn {
    margin-top: 1rem;
    color: var(--accent-regular);
    font-weight: 600;
    text-decoration: underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color 0.2s;
  }

  .back-btn:hover {
    text-decoration-color: currentColor;
  }
</style>
