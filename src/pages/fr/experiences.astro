---
import { getCollection } from "astro:content";
import FrenchBaseLayout from "../../layouts/FrenchBaseLayout.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import PortfolioPreview from "../../components/PortfolioPreview.astro";
import Hero from "../../components/Hero.astro";
import Grid from "../../components/Grid.astro";
import ItemListSchema from "../../components/ItemListSchema.astro";
import { workLabels } from '../../data/pages';

const l = workLabels['fr'];

const projects = (await getCollection("work", ({ id }) => id.startsWith('fr/')))
  .sort((a, b) => (b.data.startDate ?? b.data.publishDate).valueOf() - (a.data.startDate ?? a.data.publishDate).valueOf());
---

<FrenchBaseLayout title={l.metaTitle} description={l.metaDescription}>
  <ItemListSchema
    slot="head"
    name="Expériences Professionnelles — Djamel Bougouffa"
    url="https://djamel-bougouffa.com/fr/experiences/"
    items={projects.map(p => ({
      name: p.data.title,
      url: `https://djamel-bougouffa.com/fr/experiences/${p.id.replace(/\.md$/, '').replace(/^fr\//, '')}/`,
      description: p.data.description,
    }))}
  />
  <div class="stack gap-20">
    <main id="main-content" class="wrapper stack gap-8">
      <Hero title={l.heroTitle} tagline={l.heroTagline} align="start" />
      <div class="filter-bar">
        <button class="filter-btn active" data-filter="all">Tout</button>
        <button class="filter-btn" data-filter="esn">ESN</button>
        <button class="filter-btn" data-filter="company">Entreprise</button>
        <button class="filter-btn" data-filter="client">Mission client</button>
      </div>
      <ul class="projects-grid">
        {projects.map((project) => (
          <li data-engagement={project.data.engagementType ?? 'all'}>
            <PortfolioPreview project={project} />
          </li>
        ))}
      </ul>
    </main>
    <ContactCTA />
  </div>
</FrenchBaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLLIElement>('.projects-grid li');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      items.forEach(item => {
        const match = filter === 'all' || item.dataset.engagement === filter;
        item.style.display = match ? '' : 'none';
      });
    });
  });
</script>

<style>
  .filter-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.35rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--gray-700);
    background: transparent;
    color: var(--gray-300);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: var(--font-body);
  }

  .filter-btn:hover {
    border-color: var(--accent-regular);
    color: var(--accent-regular);
  }

  .filter-btn.active {
    background-color: var(--accent-regular);
    border-color: var(--accent-regular);
    color: var(--accent-text-over);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
