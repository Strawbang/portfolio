---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
---

<BaseLayout
  title="Message sent — Djamel Bougouffa"
  description="Your message has been sent successfully."
>
  <div class="stack gap-20">
    <main class="wrapper success">
      <div class="success-content">
        <span class="icon-wrap"><Icon icon="paper-plane-tilt" size="3em" /></span>
        <h1>Message sent!</h1>
        <p>Thanks for reaching out. I'll get back to you as soon as possible, usually within a day or two.</p>
        <a href="/" class="back-btn">← Back to home</a>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .success {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
  }

  .success-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    max-width: 36rem;
    padding: 4rem 2rem;
  }

  .icon-wrap {
    color: var(--accent-regular);
  }

  h1 {
    font-size: var(--text-3xl);
    color: var(--gray-0);
  }

  p {
    color: var(--gray-300);
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .back-btn {
    margin-top: 1rem;
    color: var(--accent-regular);
    font-weight: 600;
    text-decoration: underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color 0.2s;
  }

  .back-btn:hover {
    text-decoration-color: currentColor;
  }
</style>
