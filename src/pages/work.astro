---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";

import ContactCTA from "../components/ContactCTA.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";
import Hero from "../components/Hero.astro";
import Grid from "../components/Grid.astro";
import ItemListSchema from "../components/ItemListSchema.astro";

const projects = (await getCollection("work", ({ id }) => {
		return !id.startsWith('fr/');
   })).sort(
  (a, b) => (b.data.startDate ?? b.data.publishDate).valueOf() - (a.data.startDate ?? a.data.publishDate).valueOf()
);
---

<BaseLayout
  title="My Experience | Djamel Bougouffa"
  description="Discover Djamel Bougouffa's professional experience as a Full-Stack Software Engineer: TypeScript, React, Node.js, and DevOps across various companies."
>
  <ItemListSchema
    slot="head"
    name="Professional Experience — Djamel Bougouffa"
    url="https://djamel-bougouffa.com/work/"
    items={projects.map(p => ({
      name: p.data.title,
      url: `https://djamel-bougouffa.com/work/${p.id.replace(/\.md$/, '')}/`,
      description: p.data.description,
    }))}
  />
  <div class="stack gap-20">
    <main id="main-content" class="wrapper stack gap-8">
      <Hero
        title="My Experience"
        tagline="See my professional experiences below to get an idea of my background and expertise."
        align="start"
      />
      <ul class="projects-grid">
        {
          projects.map((project) => (
            <li>
              <PortfolioPreview project={project} />
            </li>
          ))
        }
      </ul>
    </main>
    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
