---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Icon from "../../components/Icon.astro";
import { languages } from '../../i18n/ui';
import { contactLabels, type Lang } from '../../data/about';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter(l => l !== 'en' && l !== 'fr')
    .map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const l = contactLabels[lang] ?? contactLabels['en'];
const isRtl = lang === 'ar';
---

<BaseLayout title={l.metaTitle} description={l.metaDescription}>
  <div class="stack gap-20">
    <main id="main-content" class="wrapper contact" dir={isRtl ? 'rtl' : undefined}>
      <Hero
        title={l.heroTitle}
        tagline={l.heroTagline}
        align="start"
      />

      <div class="contact-layout">
        <div class="form-section">
          <form
            name={`contact-${lang}`}
            method="POST"
            action={`/${lang}/contact/success/`}
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="contact-form"
          >
            <input type="hidden" name="form-name" value={`contact-${lang}`} />
            <p class="hidden">
              <label>{l.botField} <input name="bot-field" /></label>
            </p>

            <div class="field">
              <label for="name">{l.labelName} <span class="required">*</span></label>
              <input type="text" id="name" name="name" required placeholder={l.placeholderName} />
            </div>

            <div class="field">
              <label for="email">{l.labelEmail} <span class="required">*</span></label>
              <input type="email" id="email" name="email" required placeholder={l.placeholderEmail} />
            </div>

            <div class="field">
              <label for="subject">{l.labelSubject}</label>
              <input type="text" id="subject" name="subject" placeholder={l.placeholderSubject} />
            </div>

            <div class="field">
              <label for="message">{l.labelMessage} <span class="required">*</span></label>
              <textarea id="message" name="message" required rows="6" placeholder={l.placeholderMessage}></textarea>
            </div>

            <button type="submit" class="submit-btn">
              {l.sendButton}
              <Icon icon="paper-plane-tilt" size="1.2em" />
            </button>

          </form>
        </div>

        <aside class="info-section" aria-label={l.contactInfoLabel}>
          <div class="info-card">
            <h3><Icon icon="paper-plane-tilt" size="1.2em" /> Email</h3>
            <a href="mailto:dbougouffa@gmail.com">dbougouffa@gmail.com</a>
          </div>
          <div class="info-card">
            <h3><Icon icon="linkedin-logo" size="1.2em" /> LinkedIn</h3>
            <a href="https://www.linkedin.com/in/djamel-bougouffa" target="_blank" rel="noopener noreferrer">
              djamel-bougouffa
            </a>
          </div>
          <div class="info-card">
            <h3><Icon icon="github-logo" size="1.2em" /> GitHub</h3>
            <a href="https://github.com/strawbang" target="_blank" rel="noopener noreferrer">
              strawbang
            </a>
          </div>
          <div class="info-card availability">
            <h3><Icon icon="rocket-launch" size="1.2em" /> {l.availabilityTitle}</h3>
            <p>{l.availabilityText}</p>
          </div>
        </aside>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .contact {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .hidden {
    display: none;
  }

  .contact-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: var(--text-sm);
    color: var(--gray-300);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .required {
    color: var(--accent-regular);
  }

  input,
  textarea {
    background-color: var(--gray-999);
    border: 1px solid var(--gray-400);
    border-radius: 0.5rem;
    color: var(--gray-0);
    font-family: inherit;
    font-size: var(--text-md);
    padding: 0.75rem 1rem;
    transition: border-color 0.2s ease;
    width: 100%;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--gray-600);
  }

  input:focus,
  textarea:focus {
    border-color: var(--accent-regular);
    outline: none;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-regular) 20%, transparent);
  }

  @media (forced-colors: active) {
    input:focus,
    textarea:focus {
      outline: 3px solid ButtonText;
      outline-offset: 1px;
    }
  }

  textarea {
    resize: vertical;
    min-height: 160px;
  }

  .submit-btn {
    align-self: flex-start;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--accent-regular);
    color: var(--accent-text-over);
    border: none;
    border-radius: 999rem;
    cursor: pointer;
    font-family: inherit;
    font-size: var(--text-md);
    font-weight: 600;
    padding: 0.875rem 2rem;
    transition: background-color 0.2s ease, transform 0.1s ease;
  }

  .submit-btn:hover:not(:disabled) {
    background-color: var(--accent-dark);
    transform: translateY(-1px);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .info-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .info-card {
    background-color: var(--gray-999);
    border-radius: 0.5rem;
    padding: 1.25rem;
    box-shadow: var(--shadow-sm);
  }

  .info-card h3 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-md);
    color: var(--gray-100);
    margin-bottom: 0.5rem;
  }

  .info-card a {
    color: var(--accent-regular);
    text-decoration: none;
    font-size: var(--text-md);
  }

  .info-card a:hover {
    text-decoration: underline;
  }

  .info-card p {
    color: var(--gray-300);
    font-size: var(--text-md);
  }

  .availability h3 {
    color: var(--accent-regular);
  }

  @media (min-width: 50em) {
    .contact-layout {
      flex-direction: row;
      align-items: flex-start;
    }

    .form-section {
      flex: 2;
    }

    .info-section {
      flex: 1;
      position: sticky;
      top: 6rem;
    }
  }
</style>
