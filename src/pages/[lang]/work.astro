---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import PortfolioPreview from "../../components/PortfolioPreview.astro";
import Hero from "../../components/Hero.astro";
import { languages } from '../../i18n/ui';
import { workLabels, type Lang } from '../../data/pages';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter(l => l !== 'en' && l !== 'fr')
    .map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const l = workLabels[lang] ?? workLabels['en'];

const projects = (await getCollection("work", ({ id }) => !id.startsWith('fr/')))
  .sort((a, b) => (b.data.startDate ?? b.data.publishDate).valueOf() - (a.data.startDate ?? a.data.publishDate).valueOf());
---

<BaseLayout title={l.metaTitle} description={l.metaDescription}>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero title={l.heroTitle} tagline={l.heroTagline} align="start" />
      <ul class="projects-grid">
        {projects.map((project) => (<li><PortfolioPreview project={project} /></li>))}
      </ul>
    </main>
    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
