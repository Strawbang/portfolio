---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import ArticlePreview from '../components/ArticlePreview.astro';
import BlogPagination from '../components/BlogPagination.astro';
import Hero from '../components/Hero.astro';
import ItemListSchema from '../components/ItemListSchema.astro';
import { fetchArticles, deduplicateArticles } from "../services/articles";
import type { Article } from '../types/article';

// Fetch local blog posts
const localPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft && post.data.lang !== 'fr')
  .map(post => ({
    title: post.data.title,
    description: post.data.description,
    publishDate: post.data.publishDate,
    url: `/blog/${post.id.replace(/\.md$/, '')}/`,
    imageUrl: post.data.img,
    imageAlt: post.data.img_alt,
    platform: post.data.source ?? 'Blog',
    tags: post.data.tags,
  } as Article));

// Fetch external articles
const externalArticles = (await fetchArticles());

const allPosts = deduplicateArticles([...localPosts, ...externalArticles]);

const allTags = [...new Set(allPosts.flatMap(post => post.tags ?? []))].sort();

const PAGE_SIZE = 9;
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const pagedPosts = allPosts.slice(0, PAGE_SIZE);

---

<BaseLayout
  title="Blog | Djamel Bougouffa - Full-Stack Developer"
  description="Articles and tutorials on web development, TypeScript, React, Node.js and best practices."
>
  <ItemListSchema
    slot="head"
    name="Blog — Djamel Bougouffa"
    url="https://djamel-bougouffa.com/blog/"
    items={allPosts.map(p => ({
      name: p.title,
      url: `https://djamel-bougouffa.com${p.url}`,
      description: p.description,
    }))}
  />
  <div class="stack gap-20">
    <main id="main-content" class="wrapper stack gap-8">
      <Hero
        title="Blog"
        tagline="Discover my articles on web development, modern technologies, and programming best practices."
        align="start"
      />

      {allTags.length > 0 && (
        <div class="tag-filters" role="group" aria-label="Filter by tag">
          <button class="tag-filter active" data-tag="all">All</button>
          {allTags.map(tag => (
            <button class="tag-filter" data-tag={tag}>{tag}</button>
          ))}
        </div>
      )}

      <ul class="gallery">
        {pagedPosts.map((post) => (
          <li data-tags={(post.tags ?? []).join(',')}>
            <ArticlePreview article={post} />
          </li>
        ))}
      </ul>
      <div id="pagination-nav">
        <BlogPagination
          currentPage={1}
          totalPages={totalPages}
          nextUrl={totalPages > 1 ? '/blog/page/2/' : undefined}
        />
      </div>
    </main>
    <ContactCTA />
  </div>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
  const items = document.querySelectorAll<HTMLLIElement>('.gallery > li');

  function applyFilter(tag: string) {
    filterBtns.forEach(b => {
      b.classList.remove('active');
      b.setAttribute('aria-pressed', 'false');
    });
    const target = document.querySelector<HTMLButtonElement>(`.tag-filter[data-tag="${CSS.escape(tag)}"]`);
    const active = target ?? document.querySelector<HTMLButtonElement>('.tag-filter[data-tag="all"]');
    if (active) {
      active.classList.add('active');
      active.setAttribute('aria-pressed', 'true');
    }
    const paginationNav = document.getElementById('pagination-nav');
    items.forEach(item => {
      if (tag === 'all' || !target) {
        item.style.display = '';
      } else {
        const tags = (item.dataset.tags ?? '').split(',').map(t => t.trim()).filter(Boolean);
        item.style.display = tags.includes(tag) ? '' : 'none';
      }
    });
    if (paginationNav) {
      paginationNav.style.display = (tag === 'all' || !target) ? '' : 'none';
    }
  }

  const initialTag = new URLSearchParams(window.location.search).get('tag');
  if (initialTag) applyFilter(initialTag);

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      applyFilter(btn.dataset.tag ?? 'all');
    });
  });
</script>

<style>
  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-filter {
    padding: 0.35rem 0.9rem;
    border-radius: 999rem;
    border: 1px solid var(--gray-800);
    background: var(--gray-999);
    color: var(--gray-300);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    font-family: var(--font-body);
  }

  .tag-filter:hover {
    background: var(--gray-800);
    color: var(--gray-100);
    border-color: var(--gray-700);
  }

  .tag-filter.active {
    background: var(--accent-regular);
    color: var(--accent-text-over);
    border-color: var(--accent-regular);
    font-weight: 600;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    list-style-type: none;
    padding: 0;
    margin: 0;
  }
</style>
