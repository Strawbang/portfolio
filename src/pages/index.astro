---
import { getCollection } from "astro:content";

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from "../layouts/BaseLayout.astro";

// Component Imports
import CallToAction from "../components/CallToAction.astro";
import Grid from "../components/Grid.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";
import Pill from "../components/Pill.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";
import ArticlePreview from "../components/ArticlePreview.astro";
import SchemaOrgPerson from "../components/SchemaOrgPerson.astro";
import WebSiteSchema from "../components/WebSiteSchema.astro";

// Page section components
import ContactCTA from "../components/ContactCTA.astro";
import Skills from "../components/Skills.astro";

// Optimize Images
import { Image } from "astro:assets"
import portrait from "../../public/assets/portrait.png"

// Content Fetching: List four most recent work projects
const projects = (await getCollection("work", ({ id }) => {
		return !id.startsWith('fr/');
   }))
  .sort((a, b) => (b.data.startDate ?? b.data.publishDate).valueOf() - (a.data.startDate ?? a.data.publishDate).valueOf())
  .slice(0, 3);

const allArticles = (await getCollection('blog'))
  .filter(post => !post.data.draft && post.data.lang !== 'fr')
  .map(post => ({
    title: post.data.title,
    description: post.data.description,
    url: `/blog/${post.id.replace(/\.md$/, '')}/`,
    platform: 'Blog' as const,
    publishDate: post.data.publishDate,
    imageUrl: post.data.img
  }))
  .sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime())
  .slice(0, 3);

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<BaseLayout title="Djamel Bougouffa | Full-Stack Software Engineer & AI/GenAI" description="Portfolio of Djamel Bougouffa, Full-Stack Software Engineer specializing in TypeScript, React, Node.js, DevOps, Rust, RAG and GenAI with 5+ years of experience.">
  <main class="stack gap-20 lg:gap-48">
    <div class="wrapper stack gap-8 lg:gap-20">
      <div class="hero">
        <Hero
          title="Hello, my name is Djamel Bougouffa"
          tagline="I am a Full-Stack Software Engineer specializing in TypeScript, React, Node.js, DevOps & AI/GenAI"
          align="start"
        >
          <div class="roles">
            <Pill><Icon icon="code" size="1.33em" /> Developer</Pill>
            <Pill><Icon icon="rocket-launch" size="1.33em" /> AI/GenAI</Pill>
            <Pill><Icon icon="devops-logo" size="1.33em" /> DevOps</Pill>
            <Pill><Icon icon="desktop" size="1.33em" /> Remote</Pill>
          </div>
          <div class="download">
            <CallToAction
              href="/assets/Resume_Djamel_Bougouffa_Full_Stack_Software_Engineer.pdf"
            >
              Download Resume
              <Icon icon="arrow-right" size="1.2em" />
            </CallToAction>
          </div>
        </Hero>

        <Image src={portrait} alt="Djamel Bougouffa, Full-Stack Software Engineer portrait" width="480" height="620" loading="eager" fetchpriority="high" />
      </div>

      <Skills />
    </div>

    <div class="wrapper stack gap-20 lg:gap-48">
      <section class="section with-background with-cta">
        <header class="section-header stack gap-2 lg:gap-4">
          <h2>Selected Work</h2>
          <p>
            Take a look below at some of my featured work from the past few years, 
            where I've successfully delivered 7 operational applications across various industries.
          </p>
        </header>

        <div class="gallery">
          <ul class="projects-grid">
            {
              projects.map((project) => (
                <li>
                  <PortfolioPreview project={project} />
                </li>
              ))
            }
          </ul>
        </div>

        <div class="cta">
          <CallToAction href="/work/">
            View All
            <Icon icon="arrow-right" size="1.2em" />
          </CallToAction>
        </div>
      </section>

      <section class="section with-background bg-variant with-cta">
        <header class="section-header stack gap-2 lg:gap-4">
          <h2>Latest Articles</h2>
          <p>My latest articles from my blog, Medium and Dev.to</p>
        </header>

        <div class="gallery">
          <ul class="articles-grid">
            {
              allArticles.map((article) => (
                <li>
                  <ArticlePreview article={article} />
                </li>
              ))
            }
          </ul>
        </div>

        <div class="cta">
          <CallToAction href="/blog/">
            View Blog
            <Icon icon="arrow-right" size="1.2em" />
          </CallToAction>
        </div>
      </section>
    </div>

    <ContactCTA />
  </main>

  <WebSiteSchema slot="head" lang="en" />

  <!-- Données structurées pour les IA comme ChatGPT -->
  <SchemaOrgPerson
    name="Djamel Bougouffa"
    jobTitle="Full-Stack Software Engineer"
    description="Full-Stack Software Engineer with over 5 years of experience specializing in TypeScript, React, Node.js, DevOps, and AI/GenAI. Currently at Ippon Technologies, building AI-driven legacy modernization tools in Rust with RAG, Tree-sitter, and Model Context Protocol (MCP)."
    image="https://djamel-bougouffa.com/assets/at-work.webp"
    url="https://djamel-bougouffa.com/about/"
    email="djamel.bougouffa@gmail.com"
    sameAs={["https://github.com/strawbang", "https://www.linkedin.com/in/djamel-bougouffa/"]}
    knowsAbout={["TypeScript", "JavaScript", "React", "Node.js", "Express.js", "Next.js", "Rust", "RAG", "GenAI", "MCP", "LLM Integration", "DevOps", "Docker", "Kubernetes", "CI/CD"]}
    worksFor={{ name: "Ippon Technologies", url: "https://www.ippon.fr/" }}
    alumniOf={[
      { name: "Institut F2I", url: "https://www.f2i-institute.com/", description: "Master's degree in computer engineering / Expert Architect Web", startDate: "2020", endDate: "2021" },
      { name: "Institut F2I", url: "https://www.f2i-institute.com/", description: "Bachelor's degree in computer engineering / Digital Project Manager", startDate: "2018", endDate: "2020" },
      { name: "IRIS - Ecole supérieure d'informatique", description: "Diploma of Advanced Technician Solutions and Business Applications", startDate: "2017", endDate: "2018" },
      { name: "Lycée Léonard de Vinci de Melun", description: "Diploma of Advanced Technician Solutions and Business Applications", startDate: "2015", endDate: "2017" },
      { name: "CNED", url: "https://www.cned.fr/", description: "Diploma of Advanced Technician Solutions and Business Applications", startDate: "2014", endDate: "2015" },
      { name: "Lycée La Fayette", description: "Professional Baccalaureate in Digital Electronic Systems", startDate: "2011", endDate: "2014" },
    ]}
    knowsLanguage={["en", "fr"]}
    seeks="Open to new opportunities as a Full-Stack Software Engineer with expertise in AI/GenAI, Rust, RAG, and legacy modernization"
    availableForHire={true}
  />
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .roles {
    display: none;
  }

  .hero img {
    aspect-ratio: 5 / 4;
    object-fit: cover;
    object-position: top;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 50em) {
    .hero {
      display: grid;
      grid-template-columns: 6fr 4fr;
      padding-inline: 2.5rem;
      gap: 3.75rem;
    }

    .roles {
      margin-top: 0.5rem;
      display: flex;
      gap: 0.5rem;
    }

    .hero img {
      aspect-ratio: 3 / 4;
      border-radius: 4.5rem;
      object-fit: cover;
    }
  }

  /* ====================================================== */

  .section {
    display: grid;
    gap: 2rem;
  }

  .with-background {
    position: relative;
  }

  .section-header {
    justify-self: center;
    text-align: center;
    max-width: 50ch;
    font-size: var(--text-md);
    color: var(--gray-300);
  }


  .articles-grid,
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .section-header h2 {
    font-size: var(--text-2xl);
    color: var(--gray-0);
  }

  @media (min-width: 50em) {
    .section {
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas: "header header header header" "gallery gallery gallery gallery";
      gap: 5rem;
    }

    .section.with-cta {
      grid-template-areas: "header header header cta" "gallery gallery gallery gallery";
    }

    .section-header {
      grid-area: header;
      font-size: var(--text-lg);
    }

    .section-header h2 {
      font-size: var(--text-4xl);
    }

    .with-cta .section-header {
      justify-self: flex-start;
      text-align: left;
    }

    .gallery {
      grid-area: gallery;
    }

    .cta {
      grid-area: cta;
    }
  }

  /* ====================================================== */

  .mention-card {
    display: flex;
    height: 7rem;
    justify-content: center;
    align-items: center;
    text-align: center;
    border: 1px solid var(--gray-800);
    border-radius: 1.5rem;
    color: var(--gray-300);
    background: var(--gradient-subtle);
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 50em) {
    .mention-card {
      border-radius: 1.5rem;
      height: 9.5rem;
    }
  }
</style>
