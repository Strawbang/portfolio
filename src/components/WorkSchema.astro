---
export interface Props {
  title: string;
  description: string;
  url: string;
  imageUrl?: string;
  tags?: string[];
  keywords?: string[];
  publishDate?: string;
  lang?: string;
}

const { title, description, url, imageUrl, tags = [], keywords = [], publishDate, lang = 'en' } = Astro.props;
const allKeywords = [...tags, ...keywords];
const siteUrl = 'https://djamel-bougouffa.com';

const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description,
  url: url.startsWith('http') ? url : `${siteUrl}${url}`,
  inLanguage: lang,
  ...(imageUrl && {
    image: imageUrl.startsWith('http') ? imageUrl : `${siteUrl}${imageUrl}`,
  }),
  ...(allKeywords.length > 0 && { keywords: allKeywords.join(', ') }),
  ...(publishDate && { dateCreated: publishDate }),
  author: {
    '@type': 'Person',
    name: 'Djamel Bougouffa',
    url: `${siteUrl}/about/`,
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
