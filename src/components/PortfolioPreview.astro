---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;
const slug = id.replace(/\.md$/, '');
const isFr = slug.startsWith('fr/');
const href = isFr ? `/fr/experiences/${slug.replace('fr/', '')}` : `/work/${slug}`;
const keywords = data.keywords?.slice(0, 4) ?? [];

const locale = isFr ? 'fr-FR' : 'en-US';
const presentLabel = isFr ? 'Présent' : 'Present';

function formatDate(date: Date) {
	return date.toLocaleDateString(locale, { month: 'short', year: 'numeric' });
}

const period = data.startDate
	? `${formatDate(data.startDate)} – ${data.endDate ? formatDate(data.endDate) : presentLabel}`
	: null;
---

<article class="card">
	<a href={href} class="card-link">
		<div class="image-container">
			<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" width="600" height="338" />
		</div>
		<div class="card-body">
			<h3 class="title">{data.title}</h3>
			{data.role && <p class="role">{data.role}</p>}
			{period && <p class="period">{period}</p>}
			{keywords.length > 0 && (
				<footer>
					{keywords.map((k) => <span class="pill">{k}</span>)}
				</footer>
			)}
		</div>
	</a>
</article>

<style>
	.card {
		height: 100%;
		border-radius: 0.5rem;
		background-color: var(--gray-999);
		border: 1px solid var(--gray-800);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		overflow: hidden;
	}

	.card:hover {
		transform: translateY(-5px);
		box-shadow: var(--shadow-md);
	}

	.card-link {
		display: flex;
		flex-direction: column;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}

	.image-container {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: 0.5rem 0.5rem 0 0;
	}

	.image-container img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.card:hover .image-container img {
		transform: scale(1.03);
	}

	.card-body {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: 1rem 1.1rem 1rem;
		gap: 0.25rem;
	}

	.title {
		font-size: var(--text-lg);
		color: var(--gray-200);
		margin: 0;
		transition: color 0.2s ease;
	}

	.card:hover .title {
		color: var(--accent-regular);
	}

	.role {
		font-size: var(--text-sm);
		color: var(--accent-regular);
		margin: 0;
		font-weight: 500;
	}

	.period {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin: 0;
	}

	footer {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		margin-top: auto;
		padding-top: 0.75rem;
	}

	.pill {
		background-color: var(--accent-regular);
		color: var(--accent-text-over);
		padding: 0.15rem 0.55rem;
		border-radius: 999px;
		font-size: 0.75rem;
		line-height: 1.6;
		font-family: var(--font-body);
	}
</style>
