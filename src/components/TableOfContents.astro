---
export interface Props {
  headings: { depth: number; slug: string; text: string }[];
  label?: string;
}

const { headings, label = 'Contents' } = Astro.props;
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{toc.length > 1 && (
  <nav class="toc" aria-label={label}>
    <p class="toc-title">{label}</p>
    <ol class="toc-list">
      {toc.map(heading => (
        <li class={`toc-item depth-${heading.depth}`}>
          <a href={`#${heading.slug}`} class="toc-link" data-heading={heading.slug}>
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<script>
  let tocObserver: IntersectionObserver | null = null;

  function initTOC() {
    if (tocObserver) {
      tocObserver.disconnect();
      tocObserver = null;
    }

    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (links.length === 0) return;

    const slugs = Array.from(links).map(l => l.dataset.heading!);
    const headingEls = slugs
      .map(slug => document.getElementById(slug))
      .filter(Boolean) as HTMLElement[];

    const visible = new Set<string>();

    tocObserver = new IntersectionObserver(
      entries => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            visible.add(entry.target.id);
          } else {
            visible.delete(entry.target.id);
          }
        }
        const activeSlug = slugs.find(s => visible.has(s)) ?? '';
        links.forEach(link => {
          link.classList.toggle('active', link.dataset.heading === activeSlug);
        });
      },
      { rootMargin: '0px 0px -85% 0px', threshold: 0 }
    );

    headingEls.forEach(el => tocObserver!.observe(el));
  }

  document.addEventListener('astro:page-load', initTOC);
</script>

<style>
  .toc {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
    background: var(--gray-999);
    border: 1px solid var(--gray-800);
    border-radius: 0.75rem;
    font-size: var(--text-sm);
  }

  .toc-title {
    font-weight: 700;
    color: var(--gray-0);
    margin-bottom: 0.75rem;
    font-size: var(--text-md);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .toc-link {
    display: block;
    color: var(--gray-400);
    text-decoration: none;
    padding: 0.2rem 0;
    line-height: 1.4;
    transition: color 0.15s ease;
    border-left: 2px solid transparent;
    padding-left: 0.6rem;
  }

  .toc-item.depth-3 .toc-link {
    padding-left: 1.4rem;
    font-size: var(--text-xs);
  }

  .toc-link:hover {
    color: var(--gray-100);
  }

  .toc-link.active {
    color: var(--accent-regular);
    border-left-color: var(--accent-regular);
    font-weight: 600;
  }
</style>
